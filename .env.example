# Required for the default free stack
GEMINI_API_KEY=your_free_aistudio_key_here

# Optional alternates (for the LLM provider abstraction)
# OPENAI_API_KEY=
# OLLAMA_HOST=http://localhost:11434

# Required for voiceover generation (production only — not needed to run traces)
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=

# Required for EP7 (Graph RAG)
# NEO4J_URL=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=

# Provider selection (gemini | ollama | openai). Default: gemini
SHOW_AND_TELL_PROVIDER=gemini
